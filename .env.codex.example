# Optional defaults shared by local Codex development and Docker Compose.
# Local secrets are generated in .env.codex on first start. Docker secrets are
# generated independently in the lujie-runtime-config volume.
DATABASE_URL=file:./dev.db
CODEX_BRIDGE_URL=http://127.0.0.1:4318

# Optional API-mode defaults. API keys are configured in the app.
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.6-flash
